{
    "openapi": "3.0.0",
    "info": {
        "title": "Bank Statements API",
        "description": "API uchun Bank hisobotlari (BankStatement) to'liq qo'llanmasi",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/api/document",
            "description": "Local Development Server"
        }
    ],
    "paths": {
        "/bank-statement/": {
            "get": {
                "summary": "Ro'yxatni olish (Bank hisobotlari)",
                "description": "Barcha bank hisobotlari va ishtirokchi summa (balans) ro'yxatini qaytaradi.",
                "tags": [
                    "Bank Statement"
                ],
                "responses": {
                    "200": {
                        "description": "Muvaffaqiyatli",
                        "content": {
                            "application/json": {
                                "example": {
                                    "count": 1,
                                    "next": null,
                                    "previous": null,
                                    "results": [
                                        {
                                            "id": 1,
                                            "number": "00000001",
                                            "date": "2023-10-15T00:00:00Z",
                                            "status": "draft",
                                            "is_approved": false,
                                            "purchase_type": {
                                                "id": 1,
                                                "name": "Bojxona to'lovlari"
                                            },
                                            "employee_name": "Eshmatov Toshmat",
                                            "total_in": "12500000.00",
                                            "total_out": "500000.00",
                                            "comment": "Izoh matni",
                                            "created_at": "2023-10-15T12:00:00Z",
                                            "updated_at": "2023-10-15T12:00:00Z"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Yangi Bank hisobotini kiritish",
                "description": "Asosiy qismni ham, uning ro'yxat array(items)larini ham birgalikda 'POST' so'rovida qabul qiladi. 'number' tizim tomonidan avtomat qo'yiladi.",
                "tags": [
                    "Bank Statement"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "date": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "purchase_type": {
                                        "type": "integer"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "draft",
                                            "approved",
                                            "cancelled"
                                        ]
                                    },
                                    "comment": {
                                        "type": "string"
                                    },
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "counterparty": {
                                                    "type": "integer"
                                                },
                                                "contract": {
                                                    "type": "integer"
                                                },
                                                "entry_type": {
                                                    "type": "string",
                                                    "enum": [
                                                        "in",
                                                        "out"
                                                    ]
                                                },
                                                "amount": {
                                                    "type": "string"
                                                },
                                                "comment": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            },
                            "example": {
                                "date": "2023-10-25",
                                "purchase_type": 1,
                                "status": "draft",
                                "comment": "Bankdan tushgan so'nggi ma'lumot",
                                "items": [
                                    {
                                        "counterparty": 5,
                                        "contract": null,
                                        "entry_type": "in",
                                        "amount": "100500.00",
                                        "comment": "Soliq to'lovi"
                                    },
                                    {
                                        "counterparty": 2,
                                        "contract": 15,
                                        "entry_type": "out",
                                        "amount": "500000.00",
                                        "comment": "Material uchun"
                                    }
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Muvaffaqiyatli yaratildi"
                    }
                }
            }
        },
        "/bank-statement/{id}/": {
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "get": {
                "summary": "Bitta hisobot ma'lumotlari (Detail)",
                "description": "Hisobot haqidagi batafsil ma'lumotlar va uning ichidagi 'items' ro'yxatini to'liq ko'rsatadi.",
                "tags": [
                    "Bank Statement"
                ],
                "responses": {
                    "200": {
                        "description": "Muvaffaqiyatli",
                        "content": {
                            "application/json": {
                                "example": {
                                    "id": 1,
                                    "number": "00000001",
                                    "purchase_type": {
                                        "id": 5,
                                        "name": "Yoqilg'i mahsulotlari"
                                    },
                                    "status": "draft",
                                    "comment": "",
                                    "prefetched_items": [
                                        {
                                            "id": 15,
                                            "counterparty": {
                                                "id": 2,
                                                "name": "Uzbekneftegaz MCHJ"
                                            },
                                            "contract": {
                                                "id": 5,
                                                "number": "SH-1524"
                                            },
                                            "entry_type": "in",
                                            "amount": "1500000.00",
                                            "comment": "Avans"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "patch": {
                "summary": "Bank hisobotini tahrirlash (Qisman)",
                "description": "Bu metod orqali ma'lum bir maydonlarni yuborishingiz mumkin. Kiritish mantiqi 'update' bilan deyarli bir xil. Eski itemlarning 'id' qiymati yuborilsa shu id tahrirlanadi. 'id'siz itemlar esa yangidan bazaga yoziladi!",
                "tags": [
                    "Bank Statement"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "example": {
                                "status": "approved",
                                "comment": "Izoh o'zgardi",
                                "items": [
                                    {
                                        "id": 15,
                                        "counterparty": 2,
                                        "contract": 15,
                                        "entry_type": "out",
                                        "amount": "600000.00"
                                    },
                                    {
                                        "counterparty": 3,
                                        "contract": 12,
                                        "entry_type": "in",
                                        "amount": "150000.00"
                                    }
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Muvaffaqiyatli tahrirlandi"
                    }
                }
            },
            "put": {
                "summary": "Bank hisobotini tahrirlash (To'liq)",
                "description": "Eski itemlarning 'id' qiymati yuborilsa shu id tahrirlanadi. 'id'siz itemlar esa yangidan bazaga yoziladi!",
                "tags": [
                    "Bank Statement"
                ]
            },
            "delete": {
                "summary": "Bank hisobotini o'chirish (Soft Delete)",
                "description": "Bu tizim ma'lumotlarni jismonan emas (Soft Delete) qilib o'chiradi.",
                "tags": [
                    "Bank Statement"
                ],
                "responses": {
                    "204": {
                        "description": "Muvaffaqiyatli ochiriladi"
                    }
                }
            }
        }
    }
}